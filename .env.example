# ==================================================================
# 백워드 AI 환경변수 예시
# 실제 값은 .env(로컬) / Vercel 프로젝트 설정(배포)에 등록하세요.
# ==================================================================

# ── Firebase (클라이언트 노출 허용 — VITE_ 접두사) ──────────────
# Firebase 웹 API 키는 식별자이며, 데이터 보호는 Security Rules로 수행합니다.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── AI API 키 (서버 전용 — 절대 VITE_ 접두사를 붙이지 마세요!) ──
# VITE_ 접두사가 붙는 순간 번들에 포함되어 브라우저에 노출됩니다.
# 아래 키들은 Vercel Serverless Functions(/api)에서만 읽힙니다.
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-1.5-flash

# Gemini 대신 Claude를 쓰려면:
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-haiku-latest
